{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Laravel Server",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "serve"],
      "port": 8000
    },
    {
      "name": "Vite Dev Server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "Queue Listener",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "queue:listen", "--tries=1"]
    }
  ]
}
