APP_NAME="CAPJ +"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=pagos
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=true
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Debe quedar por encima del $timeout del Job más lento (hoy,
# ImportarCasosPendientesSgfJob = 3600s) para que la cola no considere
# "perdida" su reserva mientras sigue corriendo de verdad.
DB_QUEUE_RETRY_AFTER=3700

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

CMF_API_KEY=
CMF_API_BASE_URL=https://api.cmfchile.cl/api-sbifv3/recursos_api

MERCADOPUBLICO_API_KEY=
MERCADOPUBLICO_API_BASE_URL=https://api.mercadopublico.cl/servicios/v1/publico

SGF_PLAYWRIGHT_API_KEY=
SGF_PLAYWRIGHT_BASE_URL=

# Código institucional del cfinanciero a usar por defecto para un
# caso_pago_proveedor sin proceso_adquisicion vinculado (ver config/pago-proveedores.php).
PAGO_PROVEEDORES_CFINANCIERO_DEFAULT_CODIGO=1400

# Umbral (minutos) tras el cual un trabajo_integracion "en_progreso" se trata
# como huérfano (ver config/integraciones.php). Ajustar solo si un tipo de
# integración legítimamente tarda más que el default sin terminar.
INTEGRACIONES_UMBRAL_HUERFANO_IMPORTAR_PENDIENTES_MINUTOS=90
INTEGRACIONES_UMBRAL_HUERFANO_IMPORTAR_GRUPO_PAGO_OPERACIONES_MINUTOS=90
INTEGRACIONES_UMBRAL_HUERFANO_VERIFICAR_CASO_MINUTOS=10
INTEGRACIONES_UMBRAL_HUERFANO_DEFAULT_MINUTOS=120
