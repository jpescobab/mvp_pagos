PORT=4100
SGF_PLAYWRIGHT_API_KEY=

# stub (default, seguro) | real (usa Playwright contra el SGF real — ver
# CALIBRACION.md antes de activarlo)
SGF_MODO=stub

# Solo aplica con SGF_MODO=real. false = navegador visible (obligatorio para
# la primera corrida, supervisada por una persona). true = sin ventana.
SGF_HEADLESS=false

# Credenciales de la cuenta de automatización de SGF. Nunca versionar el .env
# real con valores verdaderos (ver .gitignore) ni loguear SGF_PASSWORD en
# ningún console.log/registro.
SGF_URL=
SGF_USUARIO=
SGF_PASSWORD=

# Ruta absoluta a storage/app/private del proyecto Laravel (mismo disco,
# ambos corren en el mismo servidor) — debe ser storage/app/private, no
# storage/app: el disco "local" de config/filesystems.php resuelve rutas
# relativas contra storage/app/private. Si se omite, se asume
# "../../storage/app/private" relativo a esta carpeta
# (services/sgf-playwright/), que ya corresponde al monolito en este repo.
LARAVEL_STORAGE_PATH=
